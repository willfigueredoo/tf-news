# PostgreSQL gerenciado (use a URL com pooling na Vercel)
DATABASE_URL=
DATABASE_POOL_MAX=5

# Inteligência editorial — Gemini API (chamada somente sob ação do usuário)
AI_PROVIDER=gemini
GEMINI_API_KEY=
AI_MODEL=gemini-3.5-flash
AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
AI_TIMEOUT_MS=42000
AI_MAX_RETRIES=0
AI_DAILY_LIMIT_USD=5
AI_DAILY_REQUEST_LIMIT=100
AI_INPUT_COST_PER_1M=1
AI_OUTPUT_COST_PER_1M=6

# WordPress REST API (Application Password)
WORDPRESS_BASE_URL=
WORDPRESS_USERNAME=
WORDPRESS_APPLICATION_PASSWORD=

# Protege /api/cron/collect
CRON_SECRET=
